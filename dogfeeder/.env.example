# Copia este archivo a .env.local y completa los valores.

# Clave compartida entre el ESP32 y la API (header x-api-key).
# Debe ser EXACTAMENTE igual al API_KEY del codigo Arduino.
DEVICE_API_KEY=cambia-esta-clave

# Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Secreta: SOLO servidor (rutas /api/dispositivo). Nunca con prefijo NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
